{% comment %}
  Renders a simple cart drawer with a heading and a close button.

  Usage:
  {% render 'simple-cart-drawer' %}
{% endcomment %}

<div id="SimpleCartDrawer" class="simple-cart-drawer" role="dialog" aria-modal="true" aria-label="{{ 'sections.cart.title' | t }}">
  <div class="simple-cart-drawer__header">
    <h2 class="simple-cart-drawer__heading">Your Cart</h2>
    <button
      type="button"
      class="simple-cart-drawer__close"
      data-simple-cart-close
      aria-label="{{ 'accessibility.close' | t }}"
    >
      {{ 'icon-close.svg' | inline_asset_content }}
    </button>
  </div>
</div>

<style>
  .simple-cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 400px;
    max-width: 100%;
    height: 100vh;
    background: #ffffff;
    box-shadow: -2px 0 8px rgba(0, 0, 0, 0.15);
    z-index: 1000;
    display: flex;
    flex-direction: column;
  }

  .simple-cart-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px;
    border-bottom: 1px solid #e5e5e5;
  }

  .simple-cart-drawer__heading {
    margin: 0;
    font-size: 18px;
    font-weight: 600;
  }

  .simple-cart-drawer__close {
    background: none;
    border: none;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .simple-cart-drawer__close svg {
    width: 20px;
    height: 20px;
  }
</style>

<script>
  (function () {
    var drawer = document.getElementById('SimpleCartDrawer');
    var closeButton = drawer && drawer.querySelector('[data-simple-cart-close]');

    if (closeButton) {
      closeButton.addEventListener('click', function () {
        drawer.remove();
      });
    }
  })();
</script>
